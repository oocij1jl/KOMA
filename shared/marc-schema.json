{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koma.local/schemas/marc-schema.json",
  "title": "KOMA MARC Draft Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "leader",
    "fields"
  ],
  "properties": {
    "leader": {
      "type": "string",
      "minLength": 1
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/controlField"
          },
          {
            "$ref": "#/$defs/dataField"
          }
        ]
      }
    }
  },
  "$defs": {
    "tag": {
      "type": "string",
      "pattern": "^[0-9]{3}$"
    },
    "subfield": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "value"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z0-9]$"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "controlField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tag",
        "value"
      ],
      "properties": {
        "tag": {
          "$ref": "#/$defs/tag"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dataField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tag",
        "ind1",
        "ind2",
        "subfields"
      ],
      "properties": {
        "tag": {
          "$ref": "#/$defs/tag"
        },
        "ind1": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "ind2": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "subfields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/subfield"
          }
        }
      }
    }
  }
}
